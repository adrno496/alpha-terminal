{
  "appId": "com.alphaterminal.app",
  "appName": "ALPHA TERMINAL",
  "webDir": "dist-mobile",
  "server": {
    "androidScheme": "https",
    "iosScheme": "alphaterminal",
    "cleartext": false
  },
  "android": {
    "backgroundColor": "#0a0a0a",
    "allowMixedContent": false,
    "captureInput": true
  },
  "ios": {
    "backgroundColor": "#0a0a0a",
    "contentInset": "always",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0a0a0a",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0a",
      "overlaysWebView": false
    }
  }
}
